# Writing Engine — environment configuration
#
# The default demo (`npm run demo`) and benchmark (`npm run benchmark`) run
# entirely on deterministic local fixtures and require NONE of these values.
# They are placeholders for the replaceable production ports (see docs/architecture.md).
# Copy this file to `.env` and fill in only what you wire up.

# --- Runtime data store ---
# Directory for filesystem JSON persistence (gitignored). Defaults to ./data.
WRITING_ENGINE_DATA_DIR=./data

# --- Source adapter selection ---
# "fixture" (default, offline) | "essays" (IMPLEMENTED: STAAR-native inbox of
# student essay submissions) | "live" (IMPLEMENTED: real NOAA NWS active alerts)
SOURCE_ADAPTER=fixture

# --- Essay submissions (EssaySubmissionSource) ---
# ESSAY_INBOX_DIR=./examples/essay-inbox  # .txt files, graded in arrival order

# --- Live feed (NwsAlertsSource; all optional) ---
# Default endpoint: https://api.weather.gov/alerts/active?area=TX
# NWS_AREA=TX
# LIVE_FEED_URL=              # full URL override (wins over NWS_AREA)
# LIVE_USER_AGENT=            # api.weather.gov requires an identifying User-Agent
# HEARTBEAT_TICKS=1
# HEARTBEAT_INTERVAL_MS=30000 # pause between live polls
# GATE_DOMAIN=                # evidence-gate domain: nws-alerts-tx (live default,
#                             # observes + refuses to write) | tx-civic-memo (override)
# An Apify actor dataset remains a documented alternative live source (deferred).
# APIFY_TOKEN=
# APIFY_ACTOR_ID=

# --- Model inference (IMPLEMENTED: npm run heartbeat honors these) ---
# MODEL_ADAPTER=openai routes the writer AND an independent judge through any
# OpenAI-compatible endpoint: a self-hosted vLLM server serving Nemotron
# (docs/references/vllm-quickstart.md) or Featherless (https://api.featherless.ai/v1).
# MODEL_ADAPTER=heuristic  # default: deterministic offline writer/evaluator
# OPENAI_BASE_URL=http://localhost:8089/v1
# OPENAI_API_KEY=
# WRITER_MODEL=nvidia/nemotron-...
# EVALUATOR_MODEL=nvidia/nemotron-...  # defaults to WRITER_MODEL; always a separate call

# --- Persistence backend (production port; not implemented in the scaffold) ---
# Supabase project for durable run/rubric/source/lesson history.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Runtime security (IMPLEMENTED: npm run heartbeat wires this when set) ---
# HiddenLayer AIDR scans ingested content fail-closed before research; with
# MODEL_ADAPTER=openai every model prompt and output is also scanned per request.
# Keys: https://aitx-key-vendor.redpond-27dfd1c6.eastus.azurecontainerapps.io/
# (event code AITX-2026) issues the OAuth2 client-credentials pair.
# HIDDENLAYER_CLIENT_ID=
# HIDDENLAYER_CLIENT_SECRET=
# HIDDENLAYER_API_URL=   # default https://api.hiddenlayer.ai
# HIDDENLAYER_AUTH_URL=  # default https://auth.hiddenlayer.ai
# HIDDENLAYER_PROJECT_ID=
